<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ShellShot" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_shellshot_launcher</item>
        <item name="android:windowSplashScreenBackground">#0E172A</item>
        <item name="android:windowSplashScreenBrandingImage">@null</item>
    </style>
</resources>

